{
  "manifest_version": 3,
  "name": "ClipDict",
  "version": "1.0",
  "description": "Clipboard dictionary — click to copy values pushed by Claude",
  "permissions": ["sidePanel", "clipboardWrite"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {}
}
